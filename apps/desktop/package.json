{
  "name": "valcomp-companion",
  "version": "2.0.1",
  "description": "Companion Windows persistente do Valcomp para vínculo Riot e recursos ao vivo.",
  "main": "src/main.js",
  "author": "Valcomp",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "test": "node --test test/*.test.js",
    "dist": "electron-builder --win portable --x64"
  },
  "devDependencies": {
    "electron": "42.4.0",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "com.cda2.valcomp.companion",
    "productName": "Valcomp Companion",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/app-icon.ico",
      "artifactName": "Valcomp Companion.exe",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "Valcomp Companion.exe",
      "requestExecutionLevel": "user"
    }
  },
  "dependencies": {
    "ws": "^8.18.3"
  }
}
