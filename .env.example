ENVIRONMENT=production
API_BASE_URL=https://ares-valorant-api.fly.dev
ALLOW_DEV_AUTH=false
ACCESS_TOKEN_TTL_SECONDS=0
REFRESH_TOKEN_TTL_SECONDS=0

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET_KEY=replace-with-fernet-key

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_JWT_SECRET=replace-with-jwt-secret
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
DATABASE_SSL=true

# Optional. Companion normally sends the live client version.
DEFAULT_CLIENT_VERSION=
STORE_SNAPSHOT_TTL_SECONDS=300
RIOT_TOKEN_PROACTIVE_REFRESH_SECONDS=900
RIOT_RELINK_NOTIFICATION_GRACE_SECONDS=86400
RIOT_COMPANION_REFRESH_GRACE_SECONDS=900
COMPANION_RIOT_SESSION_SYNC_MIN_SECONDS=60
ALLOW_UNSAFE_MUTATIONS=false
LIVE_FEATURE_ENABLED=true
LIVE_PARTY_COMMANDS_ENABLED=true
LIVE_AGENT_COMMANDS_ENABLED=true
LIVE_CHAT_COMMANDS_ENABLED=true
LIVE_LEAVE_COMMANDS_ENABLED=true
# Keep disabled until a local Swagger operation and a real client transition are validated.
LIVE_MATCH_ACCEPT_ENABLED=false
LIVE_PROTOCOL_VERSION=1
LIVE_COMMAND_TTL_SECONDS=8
LIVE_OFFLINE_AFTER_SECONDS=25
JOB_SECRET_TOKEN=replace-with-random-job-token
VALORANT_ASSETS_LANGUAGE=pt-BR

# Firebase Admin. Accepts raw JSON or base64-encoded service account JSON.
FIREBASE_PROJECT_ID=replace-with-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_JSON=replace-with-service-account-json-or-base64
